# =============================================================
# CRYPTO AI TRADING SYSTEM — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# ── Exchange API Keys ──────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=false

BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=false

# ── Proxy (use if exchange API is geo-blocked) ────────────────
# HTTP_PROXY=http://user:pass@proxy-host:port

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trader:password@localhost:5432/crypto_trading
DATABASE_SYNC_URL=postgresql://trader:password@localhost:5432/crypto_trading

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Discord ────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ── Account & Risk ─────────────────────────────────────────────
ACCOUNT_BALANCE_USDT=1000.0
RISK_PER_TRADE_PCT=1.0          # % of balance risked per trade
MAX_LEVERAGE=3
MAX_OPEN_TRADES=5
MIN_RISK_REWARD_RATIO=2.0
MAX_DAILY_TRADES=3              # max trades per day (hard limit)
MAX_DAILY_LOSS_PCT=5.0          # halt trading if daily loss >= this %

# ── Entry Order Type ──────────────────────────────────────────
# MARKET  = fills immediately at market price (default, safest)
# LIMIT   = places limit order slightly inside market for better fill price
#           auto-cancels if not filled within LIMIT_ORDER_TIMEOUT_SECONDS,
#           retries up to LIMIT_ORDER_MAX_RETRIES times at refreshed price
ENTRY_ORDER_TYPE=LIMIT
LIMIT_ENTRY_OFFSET_PCT=0.05     # place limit this % inside market (LONG=below, SHORT=above)
LIMIT_ORDER_TIMEOUT_SECONDS=60  # cancel if not filled within N seconds
LIMIT_ORDER_MAX_RETRIES=3       # max retry attempts before abandoning entry

# ── Entry Guard ───────────────────────────────────────────────
ENTRY_MAX_DEVIATION_PCT=0.8     # abort if price drifts > this % from signal price before order

# ── Stop-Loss Cap ─────────────────────────────────────────────
MAX_STOP_LOSS_PCT=2.5           # SL never further than 2.5% from entry

# ── Trailing Stop ─────────────────────────────────────────────
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION_PCT=3.0    # activate after +3% unrealised profit
TRAILING_STOP_DISTANCE_PCT=1.0      # trail SL this % behind the peak price
TRAILING_STOP_MIN_MOVE_PCT=0.3      # only update exchange SL if improvement >= this %

# ── Breakeven Stop ────────────────────────────────────────────
BREAKEVEN_STOP_ENABLED=true
BREAKEVEN_TRIGGER_PCT=2.0           # move SL to entry+0.1% after +2% profit

# ── Time-Based Exit ───────────────────────────────────────────
MAX_POSITION_HOLD_HOURS=18.0        # force-close after N hours (0 = disabled)

# ── Reversal Exit ─────────────────────────────────────────────
REVERSAL_EXIT_ENABLED=true
REVERSAL_EXIT_PCT=2.0               # exit if losing >= 2% from entry
REVERSAL_EXIT_MIN_HOURS=2.0         # only after position has been open >= N hours

# ── Signal Scoring ────────────────────────────────────────────
SIGNAL_SCORE_THRESHOLD=7            # min score to add to watchlist (max 18 pts total)
MIN_ML_CONFIDENCE=0.60              # min ML model confidence (bypassed when untrained)
SIGNAL_COOLDOWN_MINUTES=30          # cooldown after watchlist decision

# ── Watchlist / Research Phase ────────────────────────────────
WATCHLIST_CONFIRMATIONS=2           # scan cycles to confirm signal before research
RESEARCH_MIN_SCORE=6.0              # min deep research score (out of 10)
RESEARCH_MIN_MTF_ALIGNMENT=0.67     # min fraction of timeframes that must agree (2/3)

# ── Scanner ────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=60
MAX_COINS_TO_SCAN=500
MIN_VOLUME_USDT=1000000             # min 24h volume filter ($1M USDT)

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change_this_to_a_random_secret
DASHBOARD_JWT_EXPIRE_MINUTES=1440

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log

# ── Social Sentiment ──────────────────────────────────────────
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ── Reddit ────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=crypto_scanner/1.0

# ── HuggingFace (optional) ────────────────────────────────────
HUGGINGFACE_TOKEN=your_huggingface_token

# ── AI LLM Integration ────────────────────────────────────────
# Supported providers: openai | anthropic | gemini
AI_PROVIDER=
AI_MODEL=                           # e.g. gpt-4o | claude-3-5-sonnet-20241022 | gemini-1.5-pro
AI_ANALYSIS_ENABLED=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Auto Strategy Discovery ───────────────────────────────────
STRATEGY_DISCOVERY_ENABLED=true     # auto-select best strategy per trade setup
